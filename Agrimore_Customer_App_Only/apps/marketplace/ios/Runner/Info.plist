<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Agrimore</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>agrimore</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	
	<!-- Google Sign-In Configuration -->
	<key>GIDClientID</key>
	<string>240895353385-1u266vsai1gr567a7d97vjdgcf2idr2m.apps.googleusercontent.com</string>
	
	<!-- URL Schemes for Google Sign-In -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<!-- Replace with your reversed client ID -->
				<string>com.googleusercontent.apps.YOUR_REVERSED_CLIENT_ID</string>
			</array>
		</dict>
	</array>
	
	<!-- Camera & Photo Library Permissions (for product images) -->
	<key>NSCameraUsageDescription</key>
	<string>Agrimore needs camera access to take photos of products</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Agrimore needs photo library access to select product images</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Agrimore needs permission to save images to your photo library</string>
	
	<!-- Location Permissions (for delivery address) -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Agrimore needs your location to provide accurate delivery options</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>Agrimore needs your location to provide accurate delivery options</string>
	
	<!-- Microphone Permission (if you add voice search later) -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Agrimore needs microphone access for voice notes</string>
	
	<!-- Contacts Permission (if you add contact sharing) -->
	<key>NSContactsUsageDescription</key>
	<string>Agrimore needs access to contacts to share products with friends</string>
	
	<!-- App Transport Security (Allow HTTP for development) -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
</dict>
</plist>

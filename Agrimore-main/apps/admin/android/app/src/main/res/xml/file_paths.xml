<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- ========================================
         FILE PROVIDER PATHS
         Used for sharing files with other apps
         ======================================== -->
    
    <!-- External Storage Root -->
    <external-path 
        name="external_files" 
        path="." />
    
    <!-- App's Cache Directory -->
    che-path 
        name="cacheche" 
        path="." />
    
    <!-- External Cache Directory -->
    <external-cache-path 
        name="external_cache" 
        path="." />
    
    <!-- App's Internal Files Directory -->
    <files-path 
        name="files" 
        path="." />
    
    <!-- App-specific External Files Directory -->
    <external-files-path 
        name="external_app_path" 
        path="." />
    
    <!-- Root Path (Use with caution) -->
    <root-path 
        name="root" 
        path="." />
    
    <!-- ========================================
         SPECIFIC DIRECTORIES
         For organized file sharing
         ======================================== -->
    
    <!-- Images Directory -->
    <external-files-path 
        name="images" 
        path="Pictures/" />
    
    <!-- Downloads Directory -->
    <external-files-path 
        name="downloads" 
        path="Download/" />
    
    <!-- Documents Directory -->
    <external-files-path 
        name="documents" 
        path="Documents/" />
    
    <!-- Videos Directory -->
    <external-files-path 
        name="videos" 
        path="Movies/" />
    
    <!-- Temp Files Directory -->
    che-path 
        name="temp" 
        path="tempemp/" />
    
    <!-- Notification Images Cache -->
    che-path 
        name="notification_images" 
        path="notificationion_images/" />
    
    <!-- Product Images -->
    <external-files-path 
        name="product_images" 
        path="Pictures/Products/" />
    
    <!-- Profile Pictures -->
    <external-files-path 
        name="profile_images" 
        path="Pictures/Profiles/" />
    
    <!-- PDF Receipts -->
    <external-files-path 
        name="receipts" 
        path="Documents/Receipts/" />
    
    <!-- Shared Content -->
    <external-files-path 
        name="shared" 
        path="Shared/" />
</paths>

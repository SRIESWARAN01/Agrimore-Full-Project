<?xml version="1.0" encoding="utf-8"?>
<!-- ========================================
     LAUNCH SPLASH SCREEN BACKGROUND
     Customize this file for your app's splash screen
     ======================================== -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- ========================================
         BACKGROUND COLOR
         ======================================== -->
    <item android:drawable="@color/colorPrimary" />
    
    <!-- ========================================
         CENTERED APP LOGO
         Uncomment to use custom splash image
         ======================================== -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/ic_launcher" />
    </item>
    
    <!-- ========================================
         ALTERNATIVE: CUSTOM SPLASH IMAGE
         Replace @mipmap/ic_launcher with your splash image
         ======================================== -->

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    function isBootstrapAdminEmail() {
      return isAuthenticated() &&
        request.auth.token.email in [
          'admin@agrimore.com',
          'admin@admin.com',
          'agrimore@gmail.com'
        ];
    }
    
    // Check if user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Check if user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.admin == true ||
          isBootstrapAdminEmail() ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
    }
    
    // Check if user is a seller
    function isSeller() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller' &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sellerStatus == 'approved' ||
          get(/databases/$(database)/documents/sellers/$(request.auth.uid)).data.status == 'approved'
        );
    }
    
    // Check if user is a delivery partner
    function isDeliveryPartner() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'delivery_partner' &&
        get(/databases/$(database)/documents/delivery_partners/$(request.auth.uid)).data.status == 'approved';
    }
    

    // ============================================
    // USER COLLECTION
    // ============================================
    match /users/{userId} {
      // ✅ SECURITY FIX: Only authenticated users can read user data
      // Users can read their own full profile, admins can read any
      allow read: if isAuthenticated();
      
      // Users can create their own profile, admins can create for delivery partners
      allow create: if isOwner(userId) || isAdmin();
      
      // Users can update their own profile, admins can update any
      allow update: if isOwner(userId) || isAdmin();
      
      // Only admins can delete users
      allow delete: if isAdmin();
      
      // Subcollections under user
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }
      
      match /wishlist/{itemId} {
        allow read, write: if isOwner(userId);
      }
      
      match /cart/{itemId} {
        allow read, write: if isOwner(userId);
      }
      
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) || isAdmin();
      }
      
      match /chats/{chatId} {
        allow read, write: if isOwner(userId);
        
        match /messages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }
      
      match /loyalty/{docId} {
        allow read: if isOwner(userId);
        allow write: if isAdmin();
      }
      
      match /recently_viewed/{productId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ============================================
    // PRODUCTS COLLECTION
    // ============================================
    match /products/{productId} {
      // Anyone can read products (public catalog)
      allow read: if true;
      
      // Only admins or product owner (seller) can create/update/delete
      allow create: if isAdmin() || (isSeller() && request.resource.data.sellerId == request.auth.uid);
      allow update: if isAdmin() || (isSeller() && resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == request.auth.uid);
      allow delete: if isAdmin() || (isSeller() && resource.data.sellerId == request.auth.uid);
      
      // Reviews subcollection under products
      match /reviews/{reviewId} {
        // Anyone can read reviews
        allow read: if true;
        
        // Authenticated users can create reviews
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        
        // Users can update their own reviews
        allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
        
        // Users can delete their own reviews, admins can delete any
        allow delete: if isAuthenticated() && 
          (resource.data.userId == request.auth.uid || isAdmin());
      }
      
      // Review stats subcollection
      match /reviewStats/{statsId} {
        // Anyone can read stats
        allow read: if true;
        
        // Authenticated users can write (for updating stats after review)
        allow write: if isAuthenticated();
      }
    }
    
    // ============================================
    // ORDERS COLLECTION
    // ============================================
    match /orders/{orderId} {
      // Order owner can read, seller/delivery partner/admin can read all
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || 
         resource.data.sellerId == request.auth.uid ||
         (isDeliveryPartner() && resource.data.deliveryPartnerId == request.auth.uid) ||
         isDeliveryPartner() ||  // Partners can see available orders
         isAdmin());
      
      // Authenticated users can create orders
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Owner can update (for cancellation), seller/admin/delivery partner can update status
      allow update: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid ||
         resource.data.sellerId == request.auth.uid ||
         (isDeliveryPartner() && resource.data.deliveryPartnerId == request.auth.uid) ||
         (isDeliveryPartner() &&
          (!('deliveryPartnerId' in resource.data) ||
           resource.data.deliveryPartnerId == null ||
           resource.data.deliveryPartnerId == '') &&
          request.resource.data.deliveryPartnerId == request.auth.uid) ||
         isAdmin());
      
      // Only admin can delete orders
      allow delete: if isAdmin();
      
      // Order timeline subcollection
      match /timeline/{eventId} {
        allow read: if isAuthenticated() && 
          (get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid ||
           get(/databases/$(database)/documents/orders/$(orderId)).data.sellerId == request.auth.uid ||
           isDeliveryPartner() ||
           isAdmin());
        allow write: if isAdmin() ||
          (isAuthenticated() &&
           (get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid ||
            getAfter(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid)) ||
          (isSeller() &&
           get(/databases/$(database)/documents/orders/$(orderId)).data.sellerId == request.auth.uid) ||
          (isDeliveryPartner() &&
           get(/databases/$(database)/documents/orders/$(orderId)).data.deliveryPartnerId == request.auth.uid);
      }
    }
    
    // ============================================
    // CATEGORIES COLLECTION
    // ============================================
    match /categories/{categoryId} {
      // Public read access
      allow read: if true;
      
      // Only admin can write
      allow write: if isAdmin();
      
      // Subcategories
      match /subcategories/{subId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
    
    // ============================================
    // COUPONS COLLECTION
    // ============================================
    match /coupons/{couponId} {
      // Public read for coupons (display offers to guests)
      allow read: if true;
      
      // Only admin can manage coupons
      allow write: if isAdmin();
    }
    
    // ============================================
    // REVIEWS COLLECTION
    // ============================================
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;
      
      // Authenticated users can create reviews
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Users can only update their own reviews
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can delete their own reviews, admins can delete any
      allow delete: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // ============================================
    // BANNERS COLLECTION
    // ============================================
    match /banners/{bannerId} {
      // Public read
      allow read: if true;
      
      // Only admin can manage banners
      allow write: if isAdmin();
    }
    
    // ============================================
    // SPONSORED BANNERS / CAMPAIGNS
    // ============================================
    match /sponsored_banners/{bannerId} {
      // Public read for active banners
      allow read: if true;
      
      // Sellers can create their own, admins can manage all
      allow create: if isSeller() || isAdmin();
      allow update: if isAdmin() || 
        (isSeller() && resource.data.sellerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sellerId);
      allow delete: if isAdmin();
    }
    
    // ============================================
    // SECTION BANNERS COLLECTION
    // ============================================
    match /section_banners/{bannerId} {
      // Public read for section banners (displayed on marketplace home)
      allow read: if true;
      
      // Only admin can manage section banners
      allow write: if isAdmin();
    }
    
    match /campaigns/{campaignId} {
      // Campaign owner and admin can read
      allow read: if isAuthenticated() && 
        (resource.data.sellerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sellerId || isAdmin());
      
      allow create: if isSeller() || isAdmin();
      allow update, delete: if isAdmin() || 
        (isSeller() && resource.data.sellerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sellerId);
    }
    
    // ============================================
    // SELLERS COLLECTION
    // ============================================
    match /sellers/{sellerId} {
      // Public read for seller profiles
      allow read: if true;
      
      // Seller can update own profile, admin can manage all
      allow create: if isAuthenticated();
      allow update: if isOwner(sellerId) || isAdmin();
      allow delete: if isAdmin();
      
      // Seller products subcollection
      match /products/{productId} {
        allow read: if true;
        allow write: if isOwner(sellerId) || isAdmin();
      }
    }
    
    // ============================================
    // LOYALTY CONFIGURATION
    // ============================================
    match /loyalty/{docId} {
      // Public read for loyalty config
      allow read: if true;
      
      // Only admin can write
      allow write: if isAdmin();
    }
    
    match /loyalty_tiers/{tierId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ============================================
    // APP CONFIGURATION
    // ============================================
    match /app_config/{docId} {
      // Public read for app config
      allow read: if true;
      
      // Only admin can write
      allow write: if isAdmin();
    }
    
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ============================================
    // NOTIFICATIONS (Global)
    // ============================================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /notification_history/{notificationId} {
      allow read, write: if isAdmin();
    }
    
    // ============================================
    // ANALYTICS & LOGS (Admin only)
    // ============================================
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    match /logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }
    
    // ============================================
    // WISHLISTS COLLECTION (Top-level)
    // ============================================
    match /wishlists/{userId} {
      // User can read/write their own wishlist
      allow read, write: if isOwner(userId);
      
      // Wishlist items subcollection
      match /items/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ============================================
    // CARTS COLLECTION (Top-level)
    // ============================================
    match /carts/{userId} {
      // User can read/write their own cart
      allow read, write: if isOwner(userId);
      
      // Cart items subcollection
      match /items/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ============================================
    // OTP CODES (For Email OTP Auth)
    // ============================================
    match /otp_codes/{email} {
      // Only cloud functions can access
      allow read, write: if false;
    }
    
    // ============================================
    // ADDRESSES COLLECTION (Top-level)
    // ============================================
    match /addresses/{addressId} {
      // User can read their own addresses
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // User can create addresses for themselves
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // User can update/delete their own addresses
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // ============================================
    // AUTH EVENTS (Logging)
    // ============================================
    match /auth_events/{eventId} {
      // Authenticated users can log their own auth events
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Only admins can read auth events
      allow read: if isAdmin();
      
      // No one can update/delete
      allow update, delete: if false;
    }
    
    // ============================================
    // BESTSELLER SLOTS COLLECTION
    // ============================================
    match /bestseller_slots/{slotId} {
      // Public read - needed to display on marketplace home
      allow read: if true;
      
      // Only admin can manage bestseller slots
      allow write: if isAdmin();
    }
    
    // ============================================
    // CATEGORY SECTION SLOTS COLLECTION
    // ============================================
    match /category_section_slots/{slotId} {
      // Public read - needed to display on marketplace home
      allow read: if true;
      
      // Only admin can manage category sections
      allow write: if isAdmin();
    }
    
    // ============================================
    // AUTH LOGS (Login/Logout Tracking)
    // ============================================
    match /auth_logs/{logId} {
      // ✅ SECURITY FIX: Only authenticated users can create auth logs
      // Logout events should be logged before signOut() completes
      allow create: if isAuthenticated();
      
      // Only admins can read auth logs
      allow read: if isAdmin();
      
      // No one can update/delete
      allow update, delete: if false;
    }
    
    // ============================================
    // WALLETS COLLECTION
    // ============================================
    match /wallets/{userId} {
      // User can read/write their own wallet
      allow read, write: if isOwner(userId);
      
      // Allow any authenticated user to read wallets (for referral code lookup)
      allow read: if isAuthenticated();
    }
    
    // ============================================
    // WALLET TRANSACTIONS COLLECTION
    // ============================================
    match /wallet_transactions/{transactionId} {
      // User can read their own transactions
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // User can create transactions for themselves
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Admin can read all wallet transactions
      allow read: if isAdmin();
      // ✅ SECURITY FIX: Removed overly-broad 'allow create: if isAuthenticated()'
      // Only the user-scoped rule above (line 446) should control create access
    }
    
    // ============================================
    // REFERRALS COLLECTION
    // ============================================
    match /referrals/{referralId} {
      // Authenticated users can read (to check referral status)
      allow read: if isAuthenticated();
      
      // Authenticated users can create referrals
      allow create: if isAuthenticated();
      
      // No one can update/delete referrals
      allow update, delete: if false;
    }
    
    // ============================================
    // DELIVERY PARTNERS COLLECTION
    // ============================================
    match /delivery_partners/{partnerId} {
      // Partner can read own data, admin can read all
      allow read: if isAuthenticated() && 
        (isOwner(partnerId) || isAdmin());
      
      // Admin can create, or delivery partner can create their own (for set with merge)
      allow create: if isAdmin() || isOwner(partnerId);
      
      // Partner can update own location/status, admin can update all
      allow update: if isOwner(partnerId) || isAdmin();
      
      // Only admin can delete partners
      allow delete: if isAdmin();
    }
    // ============================================
    // VENDORS / SUPPLIERS COLLECTION
    // ============================================
    match /vendors/{vendorId} {
      // Vendors/Suppliers are public to read
      allow read: if true;
      // Admins manage vendors
      allow write: if isAdmin();
    }

    // ============================================
    // CUSTOMER ↔ SELLER CHAT THREADS
    // ============================================
    match /threads/{threadId} {
      // A thread can only be read if the user is the customer or the seller in the thread
      allow read: if isAuthenticated() && 
        (resource.data.customerId == request.auth.uid || 
         resource.data.sellerId == request.auth.uid || 
         isAdmin());
         
      // Any authenticated user can create a thread
      allow create: if isAuthenticated();
      
      // Updates allowed if they are participants
      allow update: if isAuthenticated() && 
        (resource.data.customerId == request.auth.uid || 
         resource.data.sellerId == request.auth.uid || 
         isAdmin());
         
      match /messages/{messageId} {
        allow read: if isAuthenticated() && 
          (get(/databases/$(database)/documents/threads/$(threadId)).data.customerId == request.auth.uid || 
           get(/databases/$(database)/documents/threads/$(threadId)).data.sellerId == request.auth.uid || 
           isAdmin());
           
        allow create: if isAuthenticated() && 
          (get(/databases/$(database)/documents/threads/$(threadId)).data.customerId == request.auth.uid || 
           get(/databases/$(database)/documents/threads/$(threadId)).data.sellerId == request.auth.uid || 
           isAdmin());
      }
    }

    // ============================================
    // SELLER PAYOUTS COLLECTION
    // ============================================
    match /seller_payouts/{payoutId} {
      // Sellers can read their own payouts, admins can read all
      allow read: if isAuthenticated() && 
        (resource.data.sellerId == request.auth.uid || isAdmin());
      
      // Only Cloud Functions (admin SDK) create payouts — no client writes
      allow create: if false;
      
      // Admins can update payout status (mark as paid)
      allow update: if isAdmin();
      
      allow delete: if false;
    }

    // ============================================
    // INVENTORY ALERTS COLLECTION
    // ============================================
    match /inventory_alerts/{alertId} {
      // Sellers can read their own alerts, admins can read all
      allow read: if isAuthenticated() && 
        (resource.data.sellerId == request.auth.uid || isAdmin());
      
      // Only Cloud Functions create alerts
      allow create: if false;
      allow update, delete: if false;
    }

    // ============================================
    // RAZORPAY ORDERS COLLECTION
    // ============================================
    match /razorpay_orders/{orderId} {
      // Only Cloud Functions create; user can read their own
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ============================================
    // VERIFIED PAYMENTS COLLECTION
    // ============================================
    match /verified_payments/{paymentId} {
      // Only Cloud Functions write; admins can read
      allow read: if isAdmin();
      allow write: if false;
    }

    // ============================================
    // PAYMENT SECURITY LOGS COLLECTION
    // ============================================
    match /payment_security_logs/{logId} {
      // Only Cloud Functions write; admins can read
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}

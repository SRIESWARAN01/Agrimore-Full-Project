rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if file size is under limit (10MB)
    function isValidFileSize() {
      return request.resource.size < 10 * 1024 * 1024;
    }
    
    // Check if the file is an image
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }
    
    // ============================================
    // PUBLIC READ ACCESS FOR ALL FILES
    // ============================================
    match /{allPaths=**} {
      allow read: if true;
    }

    // ============================================
    // PRODUCT IMAGES — Authenticated users with size/type check
    // ============================================
    match /products/{fileName} {
      allow write: if isAuthenticated() && isValidFileSize() && isImage();
    }
    match /product_images/{fileName} {
      allow write: if isAuthenticated() && isValidFileSize() && isImage();
    }

    // ============================================
    // USER PROFILE IMAGES — Only owner can upload
    // ============================================
    match /profiles/{userId}/{fileName} {
      allow write: if isAuthenticated() 
                   && request.auth.uid == userId
                   && isValidFileSize() 
                   && isImage();
    }
    match /users/{userId}/{fileName} {
      allow write: if isAuthenticated() 
                   && request.auth.uid == userId
                   && isValidFileSize() 
                   && isImage();
    }

    // ============================================
    // BANNER IMAGES — Any authenticated user (admin enforced at app level)
    // ============================================
    match /banners/{fileName} {
      allow write: if isAuthenticated() && isValidFileSize() && isImage();
    }
    match /notifications/{fileName} {
      allow write: if isAuthenticated() && isValidFileSize() && isImage();
    }
    match /sponsored/{fileName} {
      allow write: if isAuthenticated() && isValidFileSize() && isImage();
    }

    // ============================================
    // CATEGORY IMAGES
    // ============================================
    match /categories/{fileName} {
      allow write: if isAuthenticated() && isValidFileSize() && isImage();
    }

    // ============================================
    // CHAT ATTACHMENTS — Authenticated with size limit
    // ============================================
    match /chat/{threadId}/{fileName} {
      allow write: if isAuthenticated() && isValidFileSize();
    }

    // ============================================
    // SELLER DOCUMENTS — Only the seller can upload
    // ============================================
    match /seller_documents/{userId}/{fileName} {
      allow write: if isAuthenticated() 
                   && request.auth.uid == userId
                   && isValidFileSize();
    }

    // ============================================
    // DELIVERY PARTNER DOCUMENTS
    // ============================================
    match /delivery_documents/{userId}/{fileName} {
      allow write: if isAuthenticated() 
                   && request.auth.uid == userId
                   && isValidFileSize();
    }

    // ============================================
    // DELIVERY PROOF PHOTOS
    // ============================================
    match /delivery_proofs/{fileName} {
      allow write: if isAuthenticated() && isValidFileSize() && isImage();
    }
  }
}

# ============================================
# AGRIMORE FIREBASE CONFIGURATION
# ============================================
# Copy this file to .env and fill in your Firebase API keys
# NEVER commit the .env file - only .env.example

# ============================================
# FIREBASE WEB CONFIGURATION
# ============================================
FIREBASE_WEB_API_KEY=your_web_api_key_here
FIREBASE_WEB_APP_ID=your_web_app_id_here
FIREBASE_WEB_MESSAGING_SENDER_ID=your_messaging_sender_id_here
FIREBASE_WEB_PROJECT_ID=your_project_id_here
FIREBASE_WEB_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_WEB_STORAGE_BUCKET=your_project_id.firebasestorage.app
FIREBASE_WEB_MEASUREMENT_ID=your_measurement_id_here

# ============================================
# FIREBASE ANDROID CONFIGURATION
# ============================================
FIREBASE_ANDROID_API_KEY=your_android_api_key_here
FIREBASE_ANDROID_APP_ID=your_android_app_id_here
FIREBASE_ANDROID_MESSAGING_SENDER_ID=your_messaging_sender_id_here
FIREBASE_ANDROID_PROJECT_ID=your_project_id_here
FIREBASE_ANDROID_STORAGE_BUCKET=your_project_id.firebasestorage.app

# ============================================
# FIREBASE IOS CONFIGURATION
# ============================================
FIREBASE_IOS_API_KEY=your_ios_api_key_here
FIREBASE_IOS_APP_ID=your_ios_app_id_here
FIREBASE_IOS_MESSAGING_SENDER_ID=your_messaging_sender_id_here
FIREBASE_IOS_PROJECT_ID=your_project_id_here
FIREBASE_IOS_STORAGE_BUCKET=your_project_id.firebasestorage.app
FIREBASE_IOS_ANDROID_CLIENT_ID=your_android_client_id_here
FIREBASE_IOS_IOS_CLIENT_ID=your_ios_client_id_here
FIREBASE_IOS_BUNDLE_ID=com.agrimore.agrimore

# ============================================
# OTHER API KEYS
# ============================================
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# SMTP CONFIGURATION (For Email OTP)
# ============================================
# Gmail: smtp.gmail.com:587 (use App Password)
# SendGrid: smtp.sendgrid.net:587
# Zoho: smtp.zoho.com:587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
